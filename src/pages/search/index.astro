---
import Layout from '../../layouts/Layout.astro';
import Schema from '../../components/Schema.astro';
import { brandMocks } from '../../data/mockBrands';
import { blogPosts } from '../../data/blogs';

// Flatten all brands to be searchable globally
const allBrands = Object.values(brandMocks).flat();

// --- Schema Markup ---
const siteUrl = "https://malaysiamenu.my";
const pageUrl = `${siteUrl}/search/`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Search", "item": pageUrl }
  ]
};
---

<Layout title="Search Results - Malaysia Menu" description="Search for your favorite restaurant menus and prices across Malaysia.">
  <Schema item={breadcrumbSchema} />
  <section class="pt-16 pb-12 md:pt-20 md:pb-16 bg-slate-50 min-h-screen">
    <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8 mt-6">
      
      <div class="text-center mb-16">
        <h1 class="text-3xl md:text-5xl font-black text-black mb-4 tracking-tight">
          Search Results for "<span id="query-display" class="text-yellow-500"></span>"
        </h1>
        <p id="results-count" class="text-slate-600 text-lg font-medium"></p>
      </div>

      {/* Grid container to be hydrated by Client-side JS */}
      <div id="results-grid" class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-8">
      </div>

      {/* Empty State UI */}
      <div id="no-results" class="hidden text-center py-16 px-6 mt-12 bg-white rounded-[2rem] border border-slate-100 shadow-[0_4px_30px_rgba(0,0,0,0.03)] max-w-[700px] mx-auto flex-col items-center">
        <div class="w-24 h-24 bg-yellow-50 rounded-full flex items-center justify-center mb-8 mx-auto border-[6px] border-white shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-yellow-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <h2 class="text-3xl font-black text-black mb-3 block text-center">No Menus Found</h2>
        <p class="text-slate-500 text-lg mb-8 max-w-md mx-auto block leading-relaxed text-center">We couldn't find any restaurant or brand matching your search. Try adjusting your keyword or explore our full directory.</p>
        <a href="/categories/" class="inline-flex justify-center items-center bg-yellow-400 text-slate-900 font-bold py-3.5 px-8 rounded-xl hover:bg-yellow-500 hover:shadow-lg transition-all duration-300">
          Explore All Categories &rarr;
        </a>
      </div>

    </div>
  </section>

  <script is:inline define:vars={{ allBrands, blogPosts }}>
    document.addEventListener("DOMContentLoaded", () => {
      const urlParams = new URLSearchParams(window.location.search);
      const query = (urlParams.get('q') || '').trim();
      const lowerQuery = query.toLowerCase();
      
      const displayObj = document.getElementById('query-display');
      const countObj = document.getElementById('results-count');
      const gridObj = document.getElementById('results-grid');
      const noResultsObj = document.getElementById('no-results');

      if (displayObj) displayObj.textContent = query;

      if (!query) {
         if (countObj) countObj.textContent = "Please enter a valid search term.";
         return;
      }

      // 1. Filter Brands
      const filteredBrands = allBrands.filter(brand => {
        if (!brand.menu || brand.menu.length === 0) return false;
        const nameMatch = brand.name.toLowerCase().includes(lowerQuery);
        const tagMatch = brand.tags.some(tag => tag.name.toLowerCase().includes(lowerQuery));
        const descMatch = brand.desc.toLowerCase().includes(lowerQuery);
        return nameMatch || tagMatch || descMatch;
      });

      // 2. Filter Blogs
      const filteredBlogs = blogPosts.filter(post => {
        const titleMatch = post.title.toLowerCase().includes(lowerQuery);
        const excerptMatch = post.excerpt.toLowerCase().includes(lowerQuery);
        const contentMatch = post.content.toLowerCase().includes(lowerQuery);
        return titleMatch || excerptMatch || contentMatch;
      });

      if (filteredBrands.length > 0 || filteredBlogs.length > 0) {
        let resultsCountText = '';
        if (filteredBrands.length > 0) resultsCountText += `${filteredBrands.length} restaurant${filteredBrands.length > 1 ? 's' : ''}`;
        if (filteredBrands.length > 0 && filteredBlogs.length > 0) resultsCountText += ' and ';
        if (filteredBlogs.length > 0) resultsCountText += `${filteredBlogs.length} expert guide${filteredBlogs.length > 1 ? 's' : ''}`;
        
        if (countObj) countObj.innerHTML = `Found ${resultsCountText}`;
        
        let html = '';

        // Render Brands first
        if (filteredBrands.length > 0) {
          filteredBrands.forEach(brand => {
            let tagsHtml = brand.tags.map(tag => `<span class="text-[10px] font-black uppercase px-2.5 py-1 rounded shadow-sm ${tag.colors}">${tag.name}</span>`).join('');
            let brandUrl = `/${brand.category}/${brand.slug}-menu/`;

            html += `
            <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-slate-100 transition-all duration-300 hover:-translate-y-1 group flex flex-col h-full">
              <div class="h-40 md:h-48 overflow-hidden relative">
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10 transition-opacity group-hover:opacity-90"></div>
                <img src="${brand.image}" alt="${brand.name}" loading="lazy" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" />
              </div>

              <div class="p-3 md:p-6 text-center flex-grow flex flex-col">
                <div class="flex justify-center flex-wrap gap-1 mb-3 md:mb-4 -mt-8 md:-mt-10 relative z-20">
                  ${tagsHtml}
                </div>
                
                <h3 class="text-sm md:text-xl font-black text-black mb-1 md:mb-2 line-clamp-1">${brand.name}</h3>
                <p class="text-[10px] md:text-sm font-medium text-slate-500 mb-4 md:mb-6 flex-grow line-clamp-2 md:line-clamp-none">${brand.desc}</p>
                
                <a href="${brandUrl}" class="inline-flex justify-center items-center px-4 md:px-8 w-fit mx-auto bg-yellow-400 border border-yellow-500 group-hover:border-black group-hover:bg-black group-hover:text-yellow-400 text-slate-900 font-bold py-2 md:py-3 rounded-lg md:rounded-xl transition-all duration-300 shadow-sm text-xs md:text-base border-b-2 border-yellow-500">
                  View Menu
                </a>
              </div>
            </div>
            `;
          });
        }

        // Render Blogs if any
        if (filteredBlogs.length > 0) {
          html += `<div class="col-span-full mt-20 mb-8 pb-4 border-b border-slate-100"><h2 class="text-2xl md:text-4xl font-black text-black uppercase tracking-tight text-center">Related Expert Guides</h2></div>`;
          filteredBlogs.forEach(post => {
            html += `
            <a href="/blogs/${post.slug}/" class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-xl border border-slate-100 hover:border-yellow-400 transition-all duration-300 flex flex-col h-full">
              <span class="text-[10px] font-black text-yellow-600 uppercase tracking-widest mb-4">${post.category}</span>
              <h3 class="text-lg md:text-xl font-black text-black mb-3 group-hover:text-yellow-500 transition-colors leading-tight">${post.title}</h3>
              <p class="text-sm text-slate-500 font-medium mb-6 line-clamp-2 leading-relaxed flex-grow">${post.excerpt}</p>
              <span class="text-xs font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">Read Guide <span class="group-hover:translate-x-1 transition-transform">→</span></span>
            </a>
            `;
          });
        }
        
        if (gridObj) gridObj.innerHTML = html;
      } else {
        if (countObj) countObj.textContent = "";
        if (noResultsObj) noResultsObj.classList.remove('hidden');
      }
    });
  </script>
</Layout>
