---
import Layout from "../../layouts/Layout.astro";
import Schema from "../../components/Schema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";

// Consolidated static categories
const categories = [
  {
    name: "Fast Food & Burgers",
    slug: "fast-food",
    icon: "🍔",
    color: "bg-yellow-100 text-yellow-600",
    desc: "Quick bites, value meals, and iconic burgers from global and local chains.",
  },
  {
    name: "Coffee & Bakeries",
    slug: "coffee-bakeries",
    icon: "☕",
    color: "bg-yellow-100 text-yellow-700",
    desc: "Fresh brews, artisan pastries, and cozy café environments.",
  },
  {
    name: "Local & Asian",
    slug: "local-asian",
    icon: "🍚",
    color: "bg-yellow-100 text-yellow-600",
    desc: "Traditional Malaysian flavors, Nasi Lemak, and pan-Asian delights.",
  },
  {
    name: "Teas & Desserts",
    slug: "teas-desserts",
    icon: "🧋",
    color: "bg-yellow-100 text-yellow-600",
    desc: "Boba teas, sweet treats, and refreshing beverages.",
  },
  {
    name: "Japanese & Korean",
    slug: "japanese-korean",
    icon: "🍣",
    color: "bg-yellow-100 text-yellow-600",
    desc: "Sushi, ramen, K-BBQ, and authentic East Asian cuisine.",
  },
  {
    name: "Pizza & Italian",
    slug: "pizza-italian",
    icon: "🍕",
    color: "bg-yellow-50 text-yellow-500",
    desc: "Classic pizzas, pastas, and Mediterranean favorites.",
  },
  {
    name: "Western & Grilled",
    slug: "western-grilled",
    icon: "🥩",
    color: "bg-yellow-200 text-yellow-700",
    desc: "Steaks, chops, and hearty Western platters.",
  },
  {
    name: "Convenience Stores",
    slug: "convenience-stores",
    icon: "🏪",
    color: "bg-yellow-100 text-yellow-600",
    desc: "Quick grab-and-go meals, snacks, and ready-to-eat items.",
  },
  {
    name: "Buffet & Fine Dining",
    slug: "buffet-dining",
    icon: "🍽️",
    color: "bg-yellow-200 text-yellow-700",
    desc: "All-you-can-eat spreads and premium dining experiences.",
  },
  {
    name: "Sandwiches & Health",
    slug: "sandwiches-health",
    icon: "🥪",
    color: "bg-yellow-100 text-yellow-700",
    desc: "Fresh subs, salads, and health-conscious meal options.",
  },
  {
    name: "Specialty Burgers",
    slug: "specialty-burgers",
    icon: "🍔",
    color: "bg-yellow-100 text-yellow-700",
    desc: "Gourmet and craft burgers packed with unique flavors.",
  },
];

// --- Schema Markup ---
const siteUrl = "https://makanmenus.my";
const pageUrl = `${siteUrl}/categories/`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Categories", item: pageUrl },
  ],
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Restaurant Categories in Malaysia",
  description:
    "Explore Malaysia's restaurant directory by cuisine and food categories.",
  numberOfItems: categories.length,
  itemListElement: categories.map((cat, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `${siteUrl}/${cat.slug}/`,
    name: cat.name,
  })),
};
---

<Layout
  title="Explore Menu Categories | Makan Menus"
  description="Browse all restaurant menu categories on Makan Menus. Find fast food, coffee, local favorites, desserts, and more."
>
  <Schema item={[breadcrumbSchema, itemListSchema]} />

  <Breadcrumbs items={[{ name: "Categories" }]} />

  {/* Header Section */}
  <section
    class="relative pt-[134px] md:pt-[142px] pb-[70px] flex items-center justify-center min-h-[350px] overflow-hidden"
  >
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-slate-950/80 mix-blend-multiply z-10">
      </div>
      <img
        src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=2000&auto=format&fit=crop"
        alt="Food Categories"
        class="w-full h-full object-cover"
      />
    </div>

    <div class="relative z-20 max-w-[1000px] mx-auto px-4 text-center mt-6">
      <h1
        class="text-3xl md:text-5xl lg:text-[54px] font-black text-white mb-6 leading-[1.15] max-w-4xl mx-auto drop-shadow-xl text-center uppercase tracking-tight"
      >
        Explore <span class="text-yellow-400 drop-shadow-md">Categories</span>
      </h1>
      <p
        class="text-sm md:text-lg text-white mb-0 mx-auto font-medium leading-relaxed max-w-2xl drop-shadow-lg text-center opacity-90"
      >
        Discover hundreds of restaurants across Malaysia neatly organized into
        beautiful collections. Your next favourite meal starts here.
      </p>
    </div>
  </section>

  {/* Categories Grid */}
  <section class="py-[70px] bg-slate-50 relative z-20">
    <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8">
      <div
        class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-8"
      >
        {
          categories.map((cat) => (
            <a
              href={`/categories/${cat.slug}/`}
              class="group bg-white rounded-2xl p-4 md:p-6 shadow-sm hover:shadow-xl hover:border-yellow-400 hover:-translate-y-1 border border-slate-100 transition-all duration-300 relative overflow-hidden flex flex-col justify-between h-full"
            >
              <div class="relative z-10 flex flex-col items-center">
                <div
                  class={`w-10 h-10 md:w-12 md:h-12 rounded-xl flex items-center justify-center text-xl md:text-2xl mb-4 md:mb-5 mx-auto shadow-sm transition-transform group-hover:scale-110 group-hover:rotate-3 ${cat.color}`}
                >
                  {cat.icon}
                </div>
                <h2 class="text-sm md:text-lg font-black text-black mb-2 group-hover:text-yellow-500 transition-colors text-center leading-tight">
                  {cat.name}
                </h2>
                <p class="text-slate-500 font-medium text-[10px] md:text-xs leading-relaxed mb-6 text-center opacity-80 line-clamp-2 md:line-clamp-none">
                  {cat.desc}
                </p>
              </div>

              <div class="flex items-center justify-center gap-1 md:gap-2 mt-auto">
                <span class="text-[9px] md:text-sm font-black text-slate-800 uppercase tracking-widest group-hover:text-amber-500 text-center">
                  View Section
                </span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-3 w-3 md:h-4 md:w-4 text-slate-400 group-hover:text-yellow-500 group-hover:translate-x-1 transition-all"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="3"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"
                  />
                </svg>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
