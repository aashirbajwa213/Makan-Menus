---
/**
 * Global legacy redirect handler.
 * This catch-all route ensures that any old URLs starting with /categories/
 * (e.g., /categories/japanese-korean/empire-sushi-menu/) are automatically 
 * redirected to the new shorter URL structure (e.g., /japanese-korean/empire-sushi-menu/).
 */
import { brandMocks } from '../../data/mockBrands';

export function getStaticPaths() {
  const paths = [];
  const categories = Object.keys(brandMocks);
  
  categories.forEach(cat => {
    // 1. Redirect /categories/[categorySlug]/ -> /[categorySlug]/
    paths.push({ params: { path: cat } });
    
    // 2. Redirect /categories/[categorySlug]/[brandSlug]-menu/ -> /[categorySlug]/[brandSlug]-menu/
    brandMocks[cat].forEach(brand => {
      paths.push({ params: { path: `${cat}/${brand.slug}-menu` } });
      
      // 3. Handle cases where the old URL was just /categories/[categorySlug]/[brandSlug]/
      paths.push({ params: { path: `${cat}/${brand.slug}` } });
    });
  });
  
  return paths;
}

const { path } = Astro.params;

// Redirect /categories/anything to /anything
// The 301 status ensures search engines update their indexes.
return Astro.redirect(`/${path}/`, 301);
---
