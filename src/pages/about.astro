---
import Layout from '../layouts/Layout.astro';
import Schema from '../components/Schema.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = "About Us | Malaysia Menu";
const description = "Learn more about Malaysia Menu, the country's most accurate and updated restaurant menu directory. Our mission is to help foodies find verified prices and halal options across Malaysia.";

// --- Schema Markup ---
const siteUrl = "https://malaysiamenu.my";
const pageUrl = `${siteUrl}/about/`;

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": title,
  "description": description,
  "url": pageUrl,
  "mainEntity": {
    "@type": "Organization",
    "name": "Malaysia Menu"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "About", "item": pageUrl }
  ]
};
---

<Layout title={title} description={description}>
  <Schema item={[aboutSchema, breadcrumbSchema]} />
  
  <Breadcrumbs items={[{ name: 'About' }]} />

  <section class="relative pt-[134px] md:pt-[142px] pb-[70px] bg-black overflow-hidden border-b border-yellow-500/10">
        {/* Yellow Grid Lines */}
        <div class="absolute inset-0 z-0 opacity-20 bg-[linear-gradient(to_right,#facc151a_1px,transparent_1px),linear-gradient(to_bottom,#facc151a_1px,transparent_1px)] bg-[size:45px_45px]"></div>
        
        {/* Soft Yellow Glow */}
        <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(234,179,8,0.12),transparent_70%)]"></div>

        <div class="max-w-[1000px] mx-auto px-4 relative z-10 text-center">
            <h1 class="text-3xl md:text-5xl lg:text-[54px] font-black text-yellow-400 mb-6 drop-shadow-[0_0_15px_rgba(234,179,8,0.3)] uppercase tracking-tight leading-[1.15]">About Us</h1>
            <p class="text-sm md:text-lg text-white font-medium leading-relaxed max-w-2xl mx-auto opacity-90">
                malaysiamenu.my is dedicated to being your most reliable and comprehensive source for dining information throughout Malaysia. Our platform is built by food lovers who believe that knowing the latest prices and menu updates should be easy, transparent, and always available at your fingertips.
            </p>
        </div>
    </section>

    <section class="py-[70px] bg-white border-b border-slate-100">
        <div class="max-w-3xl mx-auto px-4">
            <div class="prose prose-slate max-w-none text-center">
                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Our Mission</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 font-medium text-center leading-relaxed">
                    At <strong>malaysiamenu.my</strong>, our mission is simple: to make dining out in Malaysia easier and more predictable. We understand that finding accurate and up-to-date menu prices can be frustrating. That's why we meticulously curate and verify menu data from hundreds of restaurant chains across the country.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Who We Are</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 font-medium text-center leading-relaxed">
                    We are a team of passionate food enthusiasts and tech experts based in Malaysia. We noticed a gap in the market for a clean, fast, and comprehensive directory that focuses purely on menu data and pricing. Since our launch, we've helped thousands of Malaysians plan their meals better, whether it's for a family gathering, a quick lunch, or a special celebration.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Why Choose Us?</h2>
                <div class="flex flex-col items-center space-y-6 mb-16 text-slate-600 font-medium text-sm md:text-lg">
                    <div class="flex flex-col items-center">
                        <span class="text-yellow-500 mb-2 font-black text-xl">✓</span>
                        <span><strong class="text-black">Verified Data:</strong> We cross-reference our prices with official sources and physical checks.</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="text-yellow-500 mb-2 font-black text-xl">✓</span>
                        <span><strong class="text-black">User-First Design:</strong> Our site is optimized for speed and easy navigation on mobile devices.</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="text-yellow-500 mb-2 font-black text-xl">✓</span>
                        <span><strong class="text-black">Halal Information:</strong> We clearly mark the Halal status of restaurants to help you make informed choices.</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="text-yellow-500 mb-2 font-black text-xl">✓</span>
                        <span><strong class="text-black">Comprehensive Coverage:</strong> From international fast-food giants to local kopitiam chains, we cover them all.</span>
                    </div>
                </div>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Contact Us</h2>
                <p class="text-sm md:text-lg text-slate-600 text-center font-medium leading-relaxed">
                    Have questions or feedback? We'd love to hear from you. You can reach us at <a href="mailto:contact@malaysiamenu.my" class="text-yellow-600 hover:text-yellow-700 font-black underline underline-offset-4">contact@malaysiamenu.my</a>.
                </p>
            </div>
        </div>
    </section>
</Layout>
