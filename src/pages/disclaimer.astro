---
import Layout from '../layouts/Layout.astro';
import Schema from '../components/Schema.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = "Legal Disclaimer | Makan Menus";
const description = "Official legal disclaimer for Makan Menus. Read about our independent status and content accuracy policies.";

// --- Schema Markup ---
const siteUrl = "https://makanmenus.my";
const pageUrl = `${siteUrl}/disclaimer/`;

const disclaimerSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": pageUrl,
  "keywords": "legal disclaimer, accuracy of information, independent directory"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Legal Disclaimer", "item": pageUrl }
  ]
};
---

<Layout title={title} description={description}>
  <Schema item={[disclaimerSchema, breadcrumbSchema]} />
  
  <Breadcrumbs items={[{ name: 'Legal Disclaimer' }]} />

  <section class="relative pt-[134px] md:pt-[142px] pb-[70px] bg-black overflow-hidden border-b border-yellow-500/10">
        {/* Yellow Grid Lines */}
        <div class="absolute inset-0 z-0 opacity-20 bg-[linear-gradient(to_right,#facc151a_1px,transparent_1px),linear-gradient(to_bottom,#facc151a_1px,transparent_1px)] bg-[size:45px_45px]"></div>
        
        {/* Soft Yellow Glow */}
        <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(234,179,8,0.12),transparent_70%)]"></div>

        <div class="max-w-[1000px] mx-auto px-4 relative z-10 text-center">
            <h1 class="text-3xl md:text-5xl lg:text-[54px] font-black text-yellow-400 mb-6 drop-shadow-[0_0_15px_rgba(234,179,8,0.3)] uppercase tracking-tight leading-[1.15]">Disclaimer</h1>
            <p class="text-sm md:text-lg text-white font-medium leading-relaxed max-w-2xl mx-auto opacity-90">
                The information provided on makanmenus.my is for general informational purposes only. We advise users to verify information directly with establishments.
            </p>
        </div>
    </section>

    <section class="py-[70px] bg-white border-b border-slate-100">
        <div class="max-w-3xl mx-auto px-4">
            <div class="prose prose-slate max-w-none text-center">
                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">General Information</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    All information on makanmenus.my is published in good faith and for general information purpose only. We do not make any warranties about the completeness, reliability, and accuracy of this information. Any action you take upon the information you find on this website is strictly at your own risk. makanmenus.my will not be liable for any losses and/or damages in connection with the use of our website.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Third-Party Content</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    Through our website, you can visit other websites by following hyperlinks to such external sites. While we strive to provide only quality links to useful and ethical websites, we have no control over the content and nature of these sites. These links to other websites do not imply a recommendation for all the content found on these sites.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Menu Data</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    Menus and prices can vary by location and are subject to change. Restaurant owners may update their offerings frequentlly. We aim to keep our records updated based on public information and community feedback, but we are not an official representative of any restaurant mentioned on this site.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Consent</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    By using our website, you hereby consent to our disclaimer and agree to its terms. If you require any more information or have any questions about our site's disclaimer, please feel free to contact us.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Contact Us</h2>
                <p class="text-sm md:text-lg text-slate-600 text-center font-medium leading-relaxed">
                    For any legal inquiries or clarifications, please email us at <a href="mailto:contact@makanmenus.my" class="text-yellow-600 hover:text-yellow-700 font-black underline underline-offset-4">contact@makanmenus.my</a>.
                </p>
            </div>
        </div>
    </section>
</Layout>
