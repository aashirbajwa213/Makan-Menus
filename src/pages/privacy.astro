---
import Layout from '../layouts/Layout.astro';
import Schema from '../components/Schema.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = "Privacy Policy | Makan Menus Data & Privacy Guidelines";
const description = "Our official privacy policy. Learn how Makan Menus handles your data and ensures your privacy while browsing our directory.";

// --- Schema Markup ---
const siteUrl = "https://makanmenus.my";
const pageUrl = `${siteUrl}/privacy/`;

const privacySchema = {
  "@context": "https://schema.org",
  "@type": "PrivacyPolicy",
  "name": title,
  "description": description,
  "url": pageUrl
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": pageUrl }
  ]
};
---

<Layout title={title} description={description}>
  <Schema item={[privacySchema, breadcrumbSchema]} />
  
  <Breadcrumbs items={[{ name: 'Privacy Policy' }]} />

  <section class="relative pt-[134px] md:pt-[142px] pb-[70px] bg-black overflow-hidden border-b border-yellow-500/10 text-center">
        {/* Yellow Grid Lines */}
        <div class="absolute inset-0 z-0 opacity-20 bg-[linear-gradient(to_right,#facc151a_1px,transparent_1px),linear-gradient(to_bottom,#facc151a_1px,transparent_1px)] bg-[size:45px_45px]"></div>
        
        {/* Soft Yellow Glow */}
        <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(234,179,8,0.12),transparent_70%)]"></div>

        <div class="max-w-[1000px] mx-auto px-4 relative z-10">
            <h1 class="text-3xl md:text-5xl lg:text-[54px] font-black text-yellow-400 mb-6 uppercase tracking-tight leading-[1.15]">Privacy Policy</h1>
            <p class="text-sm md:text-lg text-white font-medium leading-relaxed mx-auto max-w-2xl opacity-90">
                Your privacy is important to us. This policy outlines how makanmenus.my handles and protects your data.
            </p>
        </div>
    </section>

    <section class="py-[70px] bg-white border-b border-slate-100">
        <div class="max-w-3xl mx-auto px-4">
            <div class="prose prose-slate max-w-none text-center prose-headings:text-center prose-p:text-center">
                <p class="text-slate-500 text-xs md:text-sm italic mb-12 text-center uppercase tracking-widest font-black">Last Updated: April 2026</p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Information We Collect</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    We do not require users to create accounts or provide personal identification to browse our menu directory. However, like many websites, we may collect non-identifiable technical information such as your IP address, browser type, and pages visited to help us improve site performance and user experience.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">How We Use Your Data</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    The technical information we collect is strictly used for analytics and to ensure the security of our website. We do not sell, trade, or otherwise transfer your data to outside parties. Our goal is simply to understand which restaurant menus are most popular so we can focus our efforts on keeping that data as fresh as possible for our community.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Cookies</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    makanmenus.my uses cookies to enhance your browsing experience. Cookies are small files that a site transfers to your computer's hard drive through your web browser that enables the site to recognize your browser and capture and remember certain information for future visits.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Third-Party Links</h2>
                <p class="text-sm md:text-lg text-slate-600 mb-12 text-center font-medium leading-relaxed">
                    Occasionally, at our discretion, we may include or offer third-party products or services on our website. These third-party sites have separate and independent privacy policies. We, therefore, have no responsibility or liability for the content and activities of these linked sites.
                </p>

                <h2 class="text-2xl md:text-4xl font-black text-black mb-8 text-center uppercase tracking-tight">Contact Us regarding Privacy</h2>
                <p class="text-sm md:text-lg text-slate-600 text-center font-medium leading-relaxed">
                    If you have any questions regarding this privacy policy, you may contact us using the information on our contact page or email us at <a href="mailto:contact@makanmenus.my" class="text-yellow-600 hover:text-yellow-700 font-black underline underline-offset-4">contact@makanmenus.my</a>.
                </p>
            </div>
        </div>
    </section>
</Layout>
