---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { blogPosts } from '../../data/blogs';

const title = "Foodie Blogs & Expert Guides | Makan Menus";
const description = "Read our latest blog articles, dining hacks, and budget guides for the best restaurant experiences in Malaysia.";
---

<Layout title={title} description={description}>
  <Breadcrumbs items={[{ name: 'Expert Guides' }]} />

  <section class="relative pt-[134px] md:pt-[142px] pb-[70px] bg-black overflow-hidden border-b border-yellow-500/10">
    {/* Yellow Grid Lines */}
    <div class="absolute inset-0 z-0 opacity-20 bg-[linear-gradient(to_right,#facc151a_1px,transparent_1px),linear-gradient(to_bottom,#facc151a_1px,transparent_1px)] bg-[size:45px_45px]"></div>
    
    {/* Soft Yellow Glow */}
    <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(234,179,8,0.12),transparent_70%)]"></div>

    <div class="max-w-[1000px] mx-auto px-4 relative z-10 text-center">
      <h1 class="text-3xl md:text-5xl lg:text-[54px] font-black text-yellow-400 mb-6 drop-shadow-[0_0_15px_rgba(234,179,8,0.3)] uppercase tracking-tight leading-[1.15]">Food Blogs & Expert Guides</h1>
      <p class="text-sm md:text-lg text-white font-medium leading-relaxed max-w-2xl mx-auto opacity-90 text-center">
        Expert recommendations, budget hacks, and the latest food news to help you navigate Malaysia's vibrant dining scene.
      </p>
    </div>
  </section>

  <section class="py-[70px] bg-slate-50">
    <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-8">
        {blogPosts.map((post) => (
          <article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl border border-slate-100 transition-all duration-500 hover:-translate-y-1 flex flex-col h-full">
            <a href={`/blogs/${post.slug}/`} class="block overflow-hidden relative h-56">
              <img 
                src={post.image} 
                alt={post.title} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" 
              />
              <div class="absolute top-4 left-4">
                <span class="bg-yellow-400 text-slate-900 text-[10px] font-black uppercase tracking-widest px-3 py-1.5 rounded-full shadow-sm">
                  {post.category}
                </span>
              </div>
            </a>
            <div class="p-3 md:p-8 flex flex-col flex-grow">
              <div class="text-slate-500 text-[8px] md:text-xs font-bold uppercase tracking-widest mb-2 md:mb-3">
                {post.date}
              </div>
              <h2 class="text-sm md:text-xl font-bold text-black mb-2 md:mb-4 group-hover:text-yellow-500 transition-colors leading-tight line-clamp-2">
                <a href={`/blogs/${post.slug}/`}>{post.title}</a>
              </h2>
              <p class="text-slate-500 text-[10px] md:text-sm leading-tight md:leading-relaxed mb-4 md:mb-6 line-clamp-2">
                {post.excerpt}
              </p>
              <div class="mt-auto">
                <a href={`/blogs/${post.slug}/`} class="inline-flex items-center gap-1 md:gap-2 text-black font-bold text-[10px] md:text-sm hover:text-yellow-500 transition-colors group/link">
                  <span>Read Guide</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 md:h-4 md:w-4 transform group-hover/link:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                  </svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
