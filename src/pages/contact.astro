---
import Layout from '../layouts/Layout.astro';
import Schema from '../components/Schema.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = "Contact Us | Makan Menus";
const description = "Have a question or want to suggest a restaurant? Contact the Makan Menus team today. We value your feedback and contributions.";

// --- Schema Markup ---
const siteUrl = "https://makanmenus.my";
const pageUrl = `${siteUrl}/contact/`;

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": title,
  "description": description,
  "url": pageUrl,
  "mainEntity": {
    "@type": "Organization",
    "name": "Makan Menus"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": pageUrl }
  ]
};
---

<Layout title={title} description={description}>
  <Schema item={[contactSchema, breadcrumbSchema]} />
  
  <Breadcrumbs items={[{ name: 'Contact' }]} />

  <section class="relative pt-[134px] md:pt-[142px] pb-[70px] bg-black overflow-hidden border-b border-yellow-500/10">
        {/* Yellow Grid Lines */}
        <div class="absolute inset-0 z-0 opacity-20 bg-[linear-gradient(to_right,#facc151a_1px,transparent_1px),linear-gradient(to_bottom,#facc151a_1px,transparent_1px)] bg-[size:45px_45px]"></div>
        
        {/* Soft Yellow Glow */}
        <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(234,179,8,0.12),transparent_70%)]"></div>

        <div class="max-w-[1000px] mx-auto px-4 relative z-10 text-center">
            <h1 class="text-3xl md:text-5xl lg:text-[54px] font-black text-yellow-400 mb-6 drop-shadow-[0_0_15px_rgba(234,179,8,0.3)] uppercase tracking-tight leading-[1.15]">Contact Us</h1>
            <p class="text-sm md:text-lg text-white font-medium leading-relaxed max-w-2xl mx-auto opacity-90">
                Have a question about a restaurant menu or want to suggest an update for our directory? The makanmenus.my team is here to help you find the best dining information in Malaysia.
            </p>
        </div>
    </section>

    <section class="py-[70px] bg-white">
        <div class="max-w-[1000px] mx-auto px-4">
            <div class="flex flex-col items-center mb-16">
                   <h2 class="text-2xl md:text-4xl font-black text-black mb-6 uppercase tracking-tight text-center">Get In Touch</h2>
                   <p class="text-sm md:text-lg text-slate-600 mb-0 font-medium text-center leading-relaxed max-w-2xl">
                       We value your feedback. Whether it's a price change or a new brand suggestion, our community stays updated through shared information.
                   </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-stretch">
                <div class="flex flex-col items-center justify-center p-8 md:p-12 rounded-[2rem] bg-slate-50 border border-slate-100">

                   <div class="space-y-8 w-full max-w-md">
                       <div class="flex flex-col items-center gap-4">
                           <div class="w-12 h-12 rounded-2xl bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
                               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                               </svg>
                           </div>
                           <div class="text-center">
                               <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-1">Email Support</h3>
                               <a href="mailto:contact@makanmenus.my" class="text-xl font-bold text-slate-900 hover:text-yellow-600 transition-colors underline decoration-yellow-500/30 decoration-2 underline-offset-4">
                                   contact@makanmenus.my
                               </a>
                           </div>
                       </div>

                       <div class="flex flex-col items-center gap-4">
                           <div class="w-12 h-12 rounded-2xl bg-yellow-500/10 flex items-center justify-center flex-shrink-0">
                               <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                               </svg>
                           </div>
                           <div class="text-center">
                               <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-1">Location</h3>
                               <p class="text-xl font-bold text-slate-900">
                                   Kuala Lumpur, Malaysia
                               </p>
                           </div>
                       </div>
                   </div>
                </div>

                <div class="bg-yellow-400 p-8 md:p-12 rounded-[2rem] shadow-sm text-center flex flex-col items-center justify-center">
                    <h3 class="text-2xl md:text-4xl font-black text-slate-900 mb-6 uppercase tracking-tight text-center">Quick Inquiry</h3>
                    <p class="text-slate-800 font-bold mb-8 text-center text-sm md:text-lg leading-relaxed">
                        Our response time is typically within 24-48 business hours. For menu updates, please include the restaurant name and location to help us identify the correct data for verification.
                    </p>
                    <div class="p-6 bg-white rounded-2xl w-full">
                         <p class="text-slate-900 font-black text-center mb-0">
                             For all inquiries, please reach out directly via our email listed above.
                         </p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>
