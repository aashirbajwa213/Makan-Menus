---
import Layout from "../../layouts/Layout.astro";
import Schema from "../../components/Schema.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { brandMocks } from "../../data/mockBrands";

export async function getStaticPaths() {
  const categories = [
    {
      name: "Fast Food & Burgers",
      slug: "fast-food",
      icon: "🍔",
      color: "bg-red-50 text-red-600 border-red-100",
      desc: "Find the latest and most accurate menus for all top fast food chains and burger joints across Malaysia.",
    },
    {
      name: "Coffee & Bakeries",
      slug: "coffee-bakeries",
      icon: "☕",
      color: "bg-orange-50 text-orange-700 border-orange-100",
      desc: "Discover prices for your favorite coffees, pastries, and desserts across local and international cafes.",
    },
    {
      name: "Local & Asian",
      slug: "local-asian",
      icon: "🍚",
      color: "bg-emerald-50 text-emerald-600 border-emerald-100",
      desc: "Authentic local Malay, Chinese, and Indian cuisine prices and menus.",
    },
    {
      name: "Teas & Desserts",
      slug: "teas-desserts",
      icon: "🧋",
      color: "bg-purple-50 text-purple-600 border-purple-100",
      desc: "Explore all boba tea shops, sweet treats, and local dessert spots.",
    },
    {
      name: "Japanese & Korean",
      slug: "japanese-korean",
      icon: "🍣",
      color: "bg-indigo-50 text-indigo-600 border-indigo-100",
      desc: "Sushi, Ramen, Korean BBQ, and Fried Chicken dining guides.",
    },
    {
      name: "Pizza & Italian",
      slug: "pizza-italian",
      icon: "🍕",
      color: "bg-yellow-50 text-yellow-600 border-yellow-100",
      desc: "Craving pizza? Find the best deals and delivery menus here.",
    },
    {
      name: "Western & Grilled",
      slug: "western-grilled",
      icon: "🥩",
      color: "bg-blue-50 text-blue-600 border-blue-100",
      desc: "Steakhouses, grill platters, and classic western dining prices.",
    },
    {
      name: "Convenience Stores",
      slug: "convenience-stores",
      icon: "🏪",
      color: "bg-cyan-50 text-cyan-600 border-cyan-100",
      desc: "Ready-to-eat meals, snacks, and drinks from popular marts.",
    },
    {
      name: "Buffet & Fine Dining",
      slug: "buffet-dining",
      icon: "🍽️",
      color: "bg-teal-50 text-teal-600 border-teal-100",
      desc: "Premium dining experiences, hotel buffets, and course menus.",
    },
    {
      name: "Sandwiches & Health",
      slug: "sandwiches-health",
      icon: "🥪",
      color: "bg-lime-50 text-lime-700 border-lime-100",
      desc: "Salad bars, subway-style subs, and healthy eating options.",
    },
    {
      name: "Specialty Burgers",
      slug: "specialty-burgers",
      icon: "🍔",
      color: "bg-rose-50 text-rose-600 border-rose-100",
      desc: "Gourmet and premium smash burgers from specialized local artisans.",
    },
  ];

  return categories.map((cat) => ({
    params: { categorySlug: cat.slug },
    props: { category: cat, allCategories: categories },
  }));
}

const { category, allCategories } = Astro.props;
const brands = brandMocks[category.slug] || brandMocks["fast-food"];

// --- Schema Markup ---
const siteUrl = "https://makanmenus.my";
const pageUrl = `${siteUrl}/${category.slug}/`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": category.name, "item": pageUrl }
  ]
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${category.name} Restaurants in Malaysia`,
  "description": `A list of the best ${category.name} restaurants and their menus in Malaysia.`,
  "numberOfItems": brands.length,
  "itemListElement": brands.map((brand: any, index: number) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": `${siteUrl}/${category.slug}/${brand.slug}-menu/`,
    "name": brand.name
  }))
};
---

<Layout
  title={`${category.name} Menus with Prices Malaysia (2026 Edition)`}
  description={`Explore all ${category.name} restaurants in Malaysia. Find updated pricing, signature dishes, and official menu lists for your favorite brands.`}
>
  <Schema item={[breadcrumbSchema, itemListSchema]} />
  
  <Breadcrumbs items={[{ name: 'Categories', href: '/categories/' }, { name: category.name }]} />

  {/* Category Hero Section */}
  <section class="relative pt-[134px] md:pt-[142px] pb-[70px] bg-black text-white overflow-hidden">
    <div
      class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"
    >
    </div>

    <div
      class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center"
    >
      {/* Title */}
      <h1
        class="text-3xl md:text-5xl lg:text-[54px] font-black mb-6 leading-[1.15] uppercase tracking-tight"
      >
        {category.name}
        <br />
        <span class="text-yellow-400 drop-shadow-md">Menu with prices</span>
      </h1>

      {/* Description */}
      <p class="text-sm md:text-lg text-white mb-10 mx-auto font-medium leading-relaxed max-w-2xl opacity-90 text-center">
        Discover the most updated {category.name} in Malaysia. Verified pricing
        and menu directories for your favorite brands.
      </p>

      {/* Category Search Bar */}
      <form
        action="/search"
        method="get"
        class="max-w-[700px] mx-auto bg-white p-1 rounded-2xl shadow-[0_0_40px_rgba(251,191,36,0.3)] flex flex-col sm:flex-row items-center relative z-30 gap-1 sm:gap-0"
      >
        <div class="hidden sm:flex pl-4 text-slate-400 flex-shrink-0">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <input
          type="text"
          name="q"
          required
          placeholder={`Search brands in ${category.name}...`}
          class="w-full py-3.5 px-4 text-slate-800 focus:outline-none bg-transparent text-base md:text-lg font-medium min-w-0"
        />
        <button
          type="submit"
          class="w-full sm:w-auto bg-yellow-400 hover:bg-yellow-500 text-slate-900 font-bold py-3.5 px-8 rounded-xl transition-all shadow-md hover:shadow-yellow-400/50 whitespace-nowrap flex-shrink-0"
        >
          Find Menu
        </button>
      </form>
    </div>
  </section>

  {/* Category Filter & Navigation Removed at User's Request */}

  {/* Brands Grid Section */}
  <section class="py-[70px] bg-slate-50">
    <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 md:gap-8">
        {
          brands
            .filter((b) => b.menu && b.menu.length > 0)
            .map((brand, index) => (
            <div class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl border border-slate-100 transition-all duration-300 hover:-translate-y-1 group flex flex-col h-full">
              <div class="h-48 overflow-hidden relative">
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10 transition-opacity group-hover:opacity-90" />
                <img
                  src={brand.image}
                  alt={`${brand.name} Menu Malaysia 2026 Price List`}
                  loading={index > 2 ? "lazy" : "eager"}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
                />

                <div class="absolute top-4 left-4 z-20">
                  <span class="bg-yellow-400 text-slate-900 text-[10px] font-black uppercase px-2 py-1 rounded shadow-md border border-yellow-500">
                    ✓ Verified 2026
                  </span>
                </div>
                <div class="absolute top-4 right-4 z-20">
                  <span class="bg-white/90 backdrop-blur-sm text-slate-900 text-[10px] font-black uppercase px-2 py-1 rounded shadow-sm">
                    Top Rated
                  </span>
                </div>
              </div>

              <div class="p-3 md:p-6 text-center flex-grow flex flex-col">
                <div class="flex justify-center flex-wrap gap-1 mb-3 md:mb-4 -mt-8 md:-mt-10 relative z-20">
                  {brand.tags.map((tag: any) => (
                    <span
                      class={`text-[8px] md:text-[10px] font-black uppercase px-2 py-0.5 md:px-2.5 md:py-1 rounded shadow-sm ${tag.colors}`}
                    >
                      {tag.name}
                    </span>
                  ))}
                </div>

                <h3 class="text-sm md:text-xl font-black text-black mb-1 md:mb-2 line-clamp-1">
                  {brand.name}
                </h3>
                <p class="text-[10px] md:text-sm font-medium text-slate-500 mb-4 md:mb-6 flex-grow line-clamp-2 md:line-clamp-none">
                  {brand.desc}
                </p>

                <a
                  href={`/${category.slug}/${brand.slug}-menu/`}
                  class="inline-flex justify-center items-center px-6 md:px-8 w-fit mx-auto bg-yellow-400 border border-yellow-500 group-hover:border-black group-hover:bg-black group-hover:text-yellow-400 text-slate-900 font-bold py-2 md:py-3 rounded-lg md:rounded-xl transition-all duration-300 shadow-sm text-sm md:text-base border-b-2 border-yellow-500"
                >
                  View Full Menu
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* Other Categories Section (Footer) */}
  <section class="py-[70px] bg-white border-t border-slate-100">
    <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-4xl font-black text-black mb-4 text-center uppercase tracking-tight">Other Categories</h2>
        <p class="text-slate-600 mx-auto text-base max-w-2xl leading-relaxed text-center opacity-80">Explore more restaurant menus across different cuisines.</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {allCategories.map(cat => (
          <a href={`/${cat.slug}/`} class="group relative bg-slate-50 border border-slate-100 p-6 rounded-[2rem] hover:border-yellow-400 transition-all duration-300 transform hover:-translate-y-1 hover:shadow-lg overflow-hidden flex flex-col items-center">
            <div class={cat.color + " w-14 h-14 rounded-2xl flex items-center justify-center text-2xl mb-4 shadow-sm border border-transparent transition-transform group-hover:scale-110"}>
              {cat.icon}
            </div>
            <h3 class="font-bold text-black group-hover:text-yellow-500 transition-colors text-center text-sm leading-tight">{cat.name}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Category SEO Content & FAQ */}
  <section class="py-[70px] bg-white border-t border-slate-100">
    <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-2xl md:text-4xl font-black text-black mb-4 text-center uppercase tracking-tight">
          About {category.name} in Malaysia
        </h2>
        <p
          class="text-slate-600 mx-auto text-base max-w-2xl leading-relaxed text-center opacity-80"
        >
          The {category.name.toLowerCase()} scene in Malaysia is vibrant and constantly
          evolving, blending international favorites with unique local twists. From
          midnight cravings resolved by a 24-hour drive-thru to weekend family gatherings
          over large sharing buckets, these establishments serve millions of Malaysians
          daily.
        </p>
        <p class="text-slate-600 mx-auto text-base max-w-2xl leading-relaxed text-center opacity-80 mt-4">
          Understanding that prices fluctuate due to inflation and promotional
          cycles, exactly knowing the current menu pricing is essential for
          budgeting your next meal out. Our directory tracks these changes
          actively so you can discover the latest deals without hassle.
        </p>
      </div>

      <div class="max-w-[800px] mx-auto">
        <div class="text-center mb-12 mt-16">
          <h2 class="text-2xl md:text-4xl font-black text-black mb-4 text-center uppercase tracking-tight">
            {category.name} FAQs
          </h2>
        </div>

        <div class="space-y-4">
          {
            [
              {
                q: `Are all ${category.name.toLowerCase()} restaurants listed here Halal certified?`,
                a: "While the majority of international fast-food chains operating in Malaysia hold official JAKIM Halal certification, we highly recommend checking the specific 'Halal' tag on each brand card. Local branches may have varying statuses depending on their individual branch applications.",
              },
              {
                q: `How often are the ${category.name.toLowerCase()} prices updated?`,
                a: "We monitor major chains on a weekly basis, updating prices as soon as new menus or promotional items drop nationwide.",
              },
              {
                q: "Does the pricing include SST and Service Charge?",
                a: "Unless specified explicitly as 'Nett', most fast-food chains in Malaysia display prices subject to a 6% Sales and Service Tax (SST).",
              },
            ].map((faq) => (
              <details class="group bg-white border border-slate-200 rounded-2xl open:bg-yellow-50 open:border-yellow-400 open:shadow-md transition-all duration-300 overflow-hidden cursor-pointer">
                <summary class="flex justify-between items-center p-6 font-bold text-black text-lg md:text-xl marker:content-none [&::-webkit-details-marker]:hidden select-none outline-none text-left">
                  {faq.q}
                  <span class="transition-transform duration-300 group-open:rotate-180 bg-black text-yellow-500 rounded-full w-8 h-8 flex items-center justify-center shrink-0 shadow-sm ml-4 border-2 border-black">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                        clip-rule="evenodd"
                      />
                    </svg>
                  </span>
                </summary>
                <div class="px-6 pb-6 text-slate-700 leading-relaxed font-medium text-left">
                  <p>{faq.a}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Hide scrollbar for the filter navigation */
    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none; /* IE and Edge */
      scrollbar-width: none; /* Firefox */
    }
  </style>
</Layout>
