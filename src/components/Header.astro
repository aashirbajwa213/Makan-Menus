---
const categories = [
  { name: 'Fast Food & Burgers', slug: 'fast-food', icon: '🍔', color: 'bg-yellow-100 text-yellow-600' },
  { name: 'Coffee & Bakeries', slug: 'coffee-bakeries', icon: '☕', color: 'bg-yellow-100 text-yellow-700' },
  { name: 'Local & Asian', slug: 'local-asian', icon: '🍚', color: 'bg-yellow-100 text-yellow-600' },
  { name: 'Teas & Desserts', slug: 'teas-desserts', icon: '🧋', color: 'bg-yellow-100 text-yellow-600' },
  { name: 'Japanese & Korean', slug: 'japanese-korean', icon: '🍣', color: 'bg-yellow-100 text-yellow-600' },
  { name: 'Pizza & Italian', slug: 'pizza-italian', icon: '🍕', color: 'bg-yellow-50 text-yellow-500' },
  { name: 'Western & Grilled', slug: 'western-grilled', icon: '🥩', color: 'bg-yellow-200 text-yellow-700' },
  { name: 'Convenience Stores', slug: 'convenience-stores', icon: '🏪', color: 'bg-yellow-100 text-yellow-600' },
  { name: 'Buffet & Fine Dining', slug: 'buffet-dining', icon: '🍽️', color: 'bg-yellow-200 text-yellow-700' },
  { name: 'Sandwiches & Health', slug: 'sandwiches-health', icon: '🥪', color: 'bg-yellow-100 text-yellow-700' },
  { name: 'Specialty Burgers', slug: 'specialty-burgers', icon: '🍔', color: 'bg-yellow-100 text-yellow-700' }
];

const currentPath = Astro.url.pathname;
---
<header class="w-full fixed top-0 left-0 bg-yellow-400 shadow-md z-50 transition-all duration-300">
  <div class="max-w-[1000px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16 md:h-[72px]">
      <div class="flex items-center gap-2">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-9 h-9 rounded-xl bg-black shadow-md flex items-center justify-center transition-transform hover:scale-105">
            <span class="text-lg font-black text-yellow-400">M</span>
          </div>
          <span class="text-xl font-black text-black tracking-tight">Makan Menus</span>
        </a>
      </div>
      
      <div class="flex items-center gap-6">
        <nav class="hidden md:flex gap-4 items-center h-full">
          <a href="/" class={`font-bold transition-all px-4 py-2 rounded-xl ${currentPath === '/' ? 'bg-black text-yellow-400 shadow-md' : 'text-slate-800 hover:text-black hover:bg-yellow-500/20'}`}>Home</a>
          
          <div class="relative group h-full flex items-center">
          <span class={`font-bold transition-all flex items-center gap-1 cursor-pointer px-4 py-2 rounded-xl ${currentPath.startsWith('/categories') || categories.some(c => currentPath.startsWith('/' + c.slug)) ? 'bg-black text-yellow-400 shadow-md' : 'text-slate-800 hover:text-black hover:bg-yellow-500/20'}`}>
            Categories
            <svg xmlns="http://www.w3.org/2000/svg" class={`h-4 w-4 transition-transform group-hover:rotate-180 ${currentPath.startsWith('/categories') || categories.some(c => currentPath.startsWith('/' + c.slug)) ? 'text-yellow-400' : ''}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
            </svg>
          </span>
          
          {/* Mega Menu Dropdown */}
          <div class="absolute top-[120%] left-1/2 -translate-x-1/2 w-[850px] bg-white rounded-3xl shadow-2xl shadow-slate-900/10 border border-slate-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-3 group-hover:translate-y-0 before:content-[''] before:absolute before:-top-6 before:left-0 before:w-full before:h-8 cursor-default z-50">
            <div class="p-8">
              <div class="grid grid-cols-3 gap-x-6 gap-y-4 mb-8">
                {categories.map((cat) => (
                  <a href={`/${cat.slug}/`} class="flex items-center gap-4 p-3 rounded-2xl hover:bg-slate-50 border border-transparent hover:border-slate-100 transition-colors group/item relative">
                    <div class={`w-14 h-14 rounded-xl flex items-center justify-center text-2xl transition-transform group-hover/item:scale-110 shadow-sm group-hover/item:shadow-md ${cat.color.replace('text-', 'text-').replace('bg-', 'bg-')}`}>
                      {cat.icon}
                    </div>
                    <div>
                      <span class="block text-slate-800 font-bold text-[15px] mb-1 group-hover/item:text-black leading-tight">{cat.name}</span>
                      <span class="block text-xs text-slate-400 font-semibold group-hover/item:text-yellow-500 transition-colors">View Menus &rarr;</span>
                    </div>
                  </a>
                ))}
              </div>
              <div class="px-2">
                <a href="/categories/" class="flex justify-center items-center bg-black text-yellow-400 font-bold py-4 px-6 rounded-xl hover:bg-slate-800 hover:shadow-lg hover:-translate-y-0.5 transition-all w-full text-center text-base">
                  Explore All Categories &rarr;
                </a>
              </div>
            </div>
          </div>
        </div>

        <a href="/blogs/" class={`font-bold transition-all px-4 py-2 rounded-xl ${currentPath.startsWith('/blogs') ? 'bg-black text-yellow-400 shadow-md' : 'text-slate-800 hover:text-black hover:bg-yellow-500/20'}`}>Blogs</a>
        <a href="/about/" class={`font-bold transition-all px-4 py-2 rounded-xl ${currentPath.startsWith('/about') ? 'bg-black text-yellow-400 shadow-md' : 'text-slate-800 hover:text-black hover:bg-yellow-500/20'}`}>About</a>
        <a href="/contact/" class={`font-bold transition-all px-4 py-2 rounded-xl ${currentPath.startsWith('/contact') ? 'bg-black text-yellow-400 shadow-md' : 'text-slate-800 hover:text-black hover:bg-yellow-500/20'}`}>Contact</a>
      </nav>

      <div class="flex items-center gap-4">
        <form action="/search/" method="get" class="relative hidden sm:flex items-center group">
          <input 
            type="text" 
            name="q" 
            placeholder="Search menus..." 
            required
            class="w-10 h-10 pl-10 pr-4 rounded-full bg-transparent hover:bg-yellow-500/20 focus:w-56 focus:bg-white focus:shadow-md focus:outline-none transition-all duration-300 cursor-pointer focus:cursor-text text-black placeholder-slate-500 font-medium"
          />
          <svg xmlns="http://www.w3.org/2000/svg" class="h-[22px] w-[22px] absolute left-2 text-slate-800 pointer-events-none group-hover:text-black transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </form>
        
        <button id="mobile-menu-open" class="md:hidden text-slate-900 ml-2 p-2 rounded-lg hover:bg-yellow-500/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
      </div>
    </div>
  </div>

  {/* Mobile Menu Drawer */}
  <div id="mobile-menu-backdrop" class="fixed inset-0 bg-slate-950/60 backdrop-blur-sm z-[60] opacity-0 invisible transition-all duration-300"></div>
  
  <div id="mobile-menu" class="fixed top-0 right-0 w-[300px] h-full bg-white z-[70] translate-x-full transition-transform duration-300 ease-out shadow-2xl flex flex-col">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-yellow-400">
      <span class="text-xl font-black text-black tracking-tight">Menu</span>
      <button id="mobile-menu-close" class="p-2 rounded-xl bg-black text-yellow-400 hover:bg-slate-800 transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="flex-grow overflow-y-auto py-4">
      {/* Search in Mobile Menu */}
      <div class="px-6 mb-8">
        <form action="/search/" method="get" class="relative">
          <input 
            type="text" 
            name="q" 
            placeholder="Search menus..." 
            required
            class="w-full h-12 pl-12 pr-4 rounded-xl bg-slate-50 border border-slate-100 focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:bg-white transition-all text-black placeholder-slate-500 font-medium"
          />
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 absolute left-3.5 top-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </form>
      </div>

      <nav class="flex flex-col">
        <a href="/" class="px-6 py-3.5 text-base font-bold border-l-4 border-transparent hover:border-yellow-400 hover:bg-yellow-50 transition-all text-slate-700">Home</a>
        
        <div class="px-0">
          <button id="mobile-categories-toggle" class="w-full px-6 py-3.5 flex items-center justify-between text-base font-bold border-l-4 border-transparent hover:border-yellow-400 hover:bg-yellow-50 transition-all text-slate-700 group">
            <span class="text-slate-700">Categories</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-[.active]:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div id="mobile-categories-list" class="max-h-0 overflow-hidden bg-slate-50 transition-all duration-300 ease-in-out">
            <div class="grid grid-cols-1 gap-1 px-6 py-3">
              {categories.map((cat) => (
                <a href={`/${cat.slug}/`} class="flex items-center gap-3 p-2.5 rounded-xl hover:bg-white transition-colors">
                  <span class="text-lg">{cat.icon}</span>
                  <span class="font-bold text-slate-600 text-sm">{cat.name}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        <a href="/blogs/" class="px-6 py-3.5 text-base font-bold border-l-4 border-transparent hover:border-yellow-400 hover:bg-yellow-50 transition-all text-slate-700 border-t border-slate-50">Blogs</a>
        <a href="/about/" class="px-6 py-3.5 text-base font-bold border-l-4 border-transparent hover:border-yellow-400 hover:bg-yellow-50 transition-all text-slate-700 border-t border-slate-50">About</a>
        <a href="/contact/" class="px-6 py-3.5 text-base font-bold border-l-4 border-transparent hover:border-yellow-400 hover:bg-yellow-50 transition-all text-slate-700 border-t border-slate-50">Contact</a>
      </nav>
    </div>

    <div class="p-6 bg-slate-50 border-t border-slate-100">
      <a href="/categories/" class="flex justify-center items-center bg-black text-yellow-400 font-bold py-4 px-6 rounded-xl hover:bg-slate-800 transition-all text-center">
        Explore All &rarr;
      </a>
    </div>
  </div>

  <script is:inline>
    const setupMenu = () => {
      const openBtn = document.getElementById('mobile-menu-open');
      const closeBtn = document.getElementById('mobile-menu-close');
      const backdrop = document.getElementById('mobile-menu-backdrop');
      const menu = document.getElementById('mobile-menu');

      if (!openBtn || !closeBtn || !backdrop || !menu) return;

      const toggleMenu = (isOpen) => {
        if (isOpen) {
          backdrop.classList.remove('opacity-0', 'invisible');
          backdrop.classList.add('opacity-100', 'visible');
          menu.classList.remove('translate-x-full');
          document.body.style.overflow = 'hidden';
        } else {
          backdrop.classList.add('opacity-0', 'invisible');
          backdrop.classList.remove('opacity-100', 'visible');
          menu.classList.add('translate-x-full');
          document.body.style.overflow = 'auto';
        }
      };

      openBtn.addEventListener('click', () => toggleMenu(true));
      closeBtn.addEventListener('click', () => toggleMenu(false));
      backdrop.addEventListener('click', () => toggleMenu(false));
      
      // Close on link click
      menu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => toggleMenu(false));
      });

      // Mobile Categories Accordion
      const catToggle = document.getElementById('mobile-categories-toggle');
      const catList = document.getElementById('mobile-categories-list');
      
      if (catToggle && catList) {
        catToggle.addEventListener('click', () => {
          const isActive = catToggle.classList.toggle('active');
          if (isActive) {
            catList.style.maxHeight = catList.scrollHeight + 'px';
          } else {
            catList.style.maxHeight = '0px';
          }
        });
      }
    };

    // Run on reach page load
    setupMenu();
    document.addEventListener('astro:after-swap', setupMenu);
  </script>
</header>
